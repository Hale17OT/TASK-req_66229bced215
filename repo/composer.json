{
    "name": "studio/operations-console",
    "description": "Offline fitness studio operations & finance console (ThinkPHP 6.1 + Layui)",
    "type": "project",
    "license": "proprietary",
    "require": {
        "php": ">=8.1",
        "ext-bcmath": "*",
        "ext-pdo": "*",
        "ext-mbstring": "*",
        "ext-fileinfo": "*",
        "ext-zip": "*",
        "topthink/framework": "^6.1.0",
        "topthink/think-orm": "^2.0.50",
        "topthink/think-migration": "^3.0",
        "ramsey/uuid": "^4.7"
    },
    "require-dev": {
        "phpunit/phpunit": "^9.6",
        "symfony/var-dumper": "^6.4"
    },
    "autoload": {
        "psr-4": {
            "app\\": "app",
            "Studio\\": "extend/Studio"
        },
        "files": [
            "app/common.php"
        ]
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests/"
        }
    },
    "scripts": {
        "test": "phpunit --testdox",
        "test:coverage": "phpunit --coverage-text --coverage-html=coverage"
    },
    "config": {
        "preferred-install": "dist",
        "sort-packages": true,
        "optimize-autoloader": true,
        "allow-plugins": {
            "topthink/think-migration": true
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
