; Copy to `.env` and edit before a production `docker compose up`. Use
; semicolons for comments — ThinkPHP's env parser is INI-based.
;
; For local dev you can skip this file entirely — docker-compose.yml ships
; safe defaults (APP_ENV=development plus placeholder secrets). FieldCipher
; accepts the placeholders only when APP_ENV is dev/test; it rejects them
; at boot when APP_ENV is production|staging|live, so you cannot silently
; ship them. See app/service/security/FieldCipher.php.

APP_ENV=production
APP_DEBUG=false
APP_TIMEZONE=America/New_York

; 32-byte random secrets -- generate each with: openssl rand -hex 32
; Leave blank for dev; set both to real values before an APP_ENV=production
; run or the FieldCipher startup guard will refuse to boot.
APP_KEY=
ENCRYPTION_KEY=

; MySQL
MYSQL_ROOT_PASSWORD=root_change_me
MYSQL_DATABASE=studio_console
MYSQL_USER=studio
MYSQL_PASSWORD=studio_change_me

; Host port mappings
WEB_HOST_PORT=8080
DB_HOST_PORT=3306
