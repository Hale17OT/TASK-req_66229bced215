; Copy to `.env` before `docker compose up`. Use semicolons for comments —
; ThinkPHP's env parser is INI-based.
;
; ENCRYPTION_KEY and APP_KEY have NO fallback in docker-compose.yml — the
; compose file refuses to start if either is missing, so they must be set
; here (or exported) before the first `docker compose up`. The quickstart
; in README.md shows the one-line generator.

APP_ENV=production
APP_DEBUG=false
APP_TIMEZONE=America/New_York

; 32-byte random secrets -- generate each with: openssl rand -hex 32
;
; The two placeholders documented in FieldCipher::KNOWN_INSECURE_KEYS
; (`please_change_this_32_byte_secret_yy` and
; `studio-console-default-encryption-key-change-me`) are rejected at app
; start whenever APP_ENV is anything other than `test`/`testing`, so these
; entries are intentionally left blank — fill them in before booting.
APP_KEY=
ENCRYPTION_KEY=

; MySQL
MYSQL_ROOT_PASSWORD=root_change_me
MYSQL_DATABASE=studio_console
MYSQL_USER=studio
MYSQL_PASSWORD=studio_change_me

; Host port mappings
WEB_HOST_PORT=8080
DB_HOST_PORT=3306
